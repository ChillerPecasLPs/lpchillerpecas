---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Conteúdo indisponível · Chiller Peças"
  description="Este conteúdo está disponível apenas para o Brasil."
  variant="error"
>
  <main class="min-h-[70vh] grid place-items-center px-4 py-20 text-center bg-white">
    <div class="max-w-xl">
      <div class="font-display text-[6rem] text-brand-accent leading-none mb-4 select-none" aria-hidden="true">
        🇧🇷
      </div>
      <h1 class="font-display text-3xl sm:text-4xl text-brand-900 uppercase tracking-tight leading-[1.2] mb-4">
        Conteúdo disponível<br />somente no Brasil
      </h1>
      <p class="font-sans text-base text-brand-900/70 max-w-sm mx-auto leading-relaxed">
        Este site atende exclusivamente o mercado brasileiro. Se você está no Brasil e vê esta mensagem, entre em contato conosco pelo WhatsApp.
      </p>
    </div>
  </main>
</BaseLayout>
