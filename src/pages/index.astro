        <path d="M17.6 6.3A7.8 7.8 0 0 0 12 4a7.9 7.9 0 0 0-6.8 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.8 1h0a7.9 7.9 0 0 0 5.6-13.6zM12 19.4a6.5 6.5 0 0 1-3.3-.9l-.2-.1-2.5.6.7-2.4-.2-.3a6.6 6.6 0 1 1 12.2-3.5 6.6 6.6 0 0 1-6.7 6.6zm3.7-4.9c-.2-.1-1.2-.6-1.4-.7s-.3-.1-.5.1-.5.7-.6.8-.2.2-.4.1a5.4 5.4 0 0 1-2.6-2.3c-.2-.3.2-.3.5-1s.2-.3.1-.5-.5-1.2-.7-1.6-.3-.4-.4-.4h-.4a.8.8 0 0 0-.5.2 2.3 2.3 0 0 0-.7 1.7 4 4 0 0 0 .8 2.1 9 9 0 0 0 3.4 3c.5.2.9.3 1.2.4a2.8 2.8 0 0 0 1.3.1 2.1 2.1 0 0 0 1.4-1 1.7 1.7 0 0 0 .1-1c0-.1-.2-.2-.4-.3z"/>
      </svg>
    </button>
  </div>

  <!-- ============================================================
       STICKY MOBILE CTA
       ============================================================ -->
  <div class="sm:hidden fixed bottom-0 left-0 right-0 z-40 bg-white border-t-2 border-brand-light px-4 py-3 shadow-[0_-6px_18px_rgba(8,91,167,0.08)]">
    <button
      type="button"
      class="cta cta--primary modal-trigger w-full inline-flex items-center justify-center gap-2 bg-brand-accent text-white font-sans font-extrabold text-base py-4 rounded-full shadow-md border-0 cursor-pointer"
      data-open-whatsapp-modal
      data-gtm-event="cta_click"
      data-gtm-location="sticky_mobile"
      data-gtm-label="cotar_pelo_whatsapp_agora"
      data-gtm-category="whatsapp"
    >
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5" aria-hidden="true">
        <path d="M17.6 6.3A7.8 7.8 0 0 0 12 4a7.9 7.9 0 0 0-6.8 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.8 1h0a7.9 7.9 0 0 0 5.6-13.6z"/>
      </svg>
      Cotar pelo WhatsApp agora
    </button>
  </div>

  <!-- ============================================================
       MODAL WHATSAPP — único, atende todos os triggers
       ============================================================ -->
  <WhatsAppModal waNumber={site.whatsapp} webhookUrl={webhookUrl} waMessage={site.mensagemWhatsapp} />

  <style>
    html { scroll-behavior: smooth; }
    @media (max-width: 640px) {
      footer { padding-bottom: 80px; }
    }
    /* Remove default marker do <summary> no Safari */
    .faq-item summary::-webkit-details-marker { display: none; }
  </style>
</BaseLayout>
