---
import { getEntry, getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WhatsAppModal from '../components/WhatsAppModal.astro';

const site = (await getEntry('site', 'config'))!.data;
const categorias = (await getCollection('categorias')).sort((a, b) => a.data.ordem - b.data.ordem);
const marcas = await getCollection('marcas');
const depoimentos = await getCollection('depoimentos');

// FAQ (carregado do content collection)
let faqEntries: Array<{ id: string; pergunta: string; resposta: string }> = [];
try {
  const faqAll = await getCollection('faq');
  faqEntries = faqAll
    .sort((a, b) => a.data.ordem - b.data.ordem)
    .map((e) => ({ id: e.data.id, pergunta: e.data.pergunta, resposta: e.data.resposta }));
} catch {
  faqEntries = [];
}

// Webhook vem do config (fallback pro valor conhecido caso campo ausente)
const webhookUrl = site.webhookLead ?? 'https://webhook.hablla.com/v1/69eb660b9a7223d20a094b05';

// Marcas mantidas no <ul class="sr-only"> da seção de marquee — lista textual pra leitores de tela.
// O marquee visível agora exibe a frase "Trabalhamos com as melhores marcas..." em loop.

// Badges rotativos para categorias (todas com PRONTA ENTREGA por enquanto)
const categoryBadges: Record<string, string> = {
  compressores: 'PRONTA ENTREGA',
  valvulas: 'PRONTA ENTREGA',
  'oleos-sinteticos': 'PRONTA ENTREGA',
  filtros: 'PRONTA ENTREGA',
  'motores-ventiladores': 'PRONTA ENTREGA',
  'placas-modulos': 'PRONTA ENTREGA',
};

// Iniciais para avatar placeholder
const getInitials = (nome: string) =>
  nome
    .split(' ')
    .map((n) => n[0])
    .slice(0, 2)
    .join('')
    .toUpperCase();
---

<BaseLayout variant="v4" title="Chiller Peças — Peças originais para chillers e refrigeração industrial">
  <!-- ============================================================
       HEADER — sticky, com logo + mini CTA que abre modal
       ============================================================ -->
  <header class="sticky top-0 z-40 bg-white border-b-2 border-brand-light" role="banner">
    <div class="max-w-7xl mx-auto px-4 md:px-8 h-16 flex items-center justify-between">
      <a
        href="#top"
        class="nav-brand flex items-center gap-2"
        data-gtm-event="cta_click"
        data-gtm-location="header"
        data-gtm-label="logo_home"
        data-gtm-category="navegacao"
        aria-label="Chiller Peças — voltar ao topo"
      >
        <img
          src="/logo.png"
          alt="Chiller Peças"
          width="180"
          height="40"
          class="h-9 md:h-10 w-auto"
          fetchpriority="high"
        />
      </a>
      <nav class="nav hidden md:flex items-center gap-7 font-sans text-sm font-semibold text-brand-900" aria-label="Principal">
        <a href="#categorias" class="nav-link hover:text-brand-500 transition-colors">Categorias</a>
        <a href="#marcas" class="nav-link hover:text-brand-500 transition-colors">Marcas</a>
        <a href="#depoimentos" class="nav-link hover:text-brand-500 transition-colors">Clientes</a>
        <a href="#sobre" class="nav-link hover:text-brand-500 transition-colors">Sobre</a>
        <a href="#faq" class="nav-link hover:text-brand-500 transition-colors">FAQ</a>
      </nav>
      <button
        type="button"
        class="cta modal-trigger group inline-flex items-center gap-2 bg-brand-accent text-white font-sans font-bold text-sm px-4 py-2.5 rounded-full shadow-[0_6px_0_0_#c46400] hover:shadow-[0_2px_0_0_#c46400] hover:translate-y-[4px] transition-all"
        data-open-whatsapp-modal
        data-gtm-event="cta_click"
        data-gtm-location="header"
        data-gtm-label="cotar_agora"
        data-gtm-category="whatsapp"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4" aria-hidden="true">
          <path d="M17.6 6.3A7.8 7.8 0 0 0 12 4a7.9 7.9 0 0 0-6.8 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.8 1h0a7.9 7.9 0 0 0 5.6-13.6zM12 19.4a6.5 6.5 0 0 1-3.3-.9l-.2-.1-2.5.6.7-2.4-.2-.3a6.6 6.6 0 1 1 12.2-3.5 6.6 6.6 0 0 1-6.7 6.6zm3.7-4.9c-.2-.1-1.2-.6-1.4-.7s-.3-.1-.5.1-.5.7-.6.8-.2.2-.4.1a5.4 5.4 0 0 1-2.6-2.3c-.2-.3.2-.3.5-1s.2-.3.1-.5-.5-1.2-.7-1.6-.3-.4-.4-.4h-.4a.8.8 0 0 0-.5.2 2.3 2.3 0 0 0-.7 1.7 4 4 0 0 0 .8 2.1 9 9 0 0 0 3.4 3c.5.2.9.3 1.2.4a2.8 2.8 0 0 0 1.3.1 2.1 2.1 0 0 0 1.4-1 1.7 1.7 0 0 0 .1-1c0-.1-.2-.2-.4-.3z" />
        </svg>
        <span>Cotar agora</span>
      </button>
    </div>
  </header>

  <main id="top">
    <!-- ============================================================
         HERO
         ============================================================ -->
    <section class="relative overflow-hidden bg-white" aria-labelledby="hero-title">
      <!-- Foto da fachada à direita (Opção B: lado direito assumido) -->
      <div class="absolute inset-y-0 right-0 w-full md:w-3/4 lg:w-3/5 pointer-events-none" aria-hidden="true">
        <picture>
          <source srcset="/images/loja-hero.webp" type="image/webp" />
          <img
            src="/images/loja-hero.jpg"
            alt=""
            class="absolute inset-0 w-full h-full object-cover object-center"
            loading="eager"
            decoding="async"
            fetchpriority="high"
          />
        </picture>
        <!-- Fade branco: cobre o lado esquerdo (onde fica o texto) -->
        <div class="absolute inset-0 bg-gradient-to-r from-white from-0% via-white/85 via-25% to-transparent to-65% md:to-55%"></div>
        <!-- Mobile: véu branco extra pra texto sobreviver -->
        <div class="absolute inset-0 bg-white/55 md:hidden"></div>
        <!-- Tint azul sutil pra integrar com a paleta -->
        <div class="absolute inset-0 bg-gradient-to-l from-brand-900/10 to-transparent"></div>
      </div>
      <!-- Luz ambiente azul (mantida) — fica por cima da foto adicionando ar -->
      <div class="absolute -right-20 top-0 w-[520px] h-[520px] bg-brand-500 rounded-full blur-3xl opacity-15 pointer-events-none" aria-hidden="true"></div>

      <div class="relative max-w-7xl mx-auto px-4 md:px-8 pt-10 pb-16 md:pt-20 md:pb-28">
        <div class="grid lg:grid-cols-12 gap-8 items-center">
          <div class="lg:col-span-7 relative">
            <!-- Badge urgência -->
            <div class="inline-flex items-center gap-2 bg-brand-accent/15 border border-brand-accent text-brand-accent font-sans font-bold text-xs tracking-wider uppercase px-3 py-1.5 rounded-full mb-6">
              <span class="relative flex h-2 w-2">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
              </span>
              Pronta entrega · Despacho em 24h em SP capital
            </div>

            <h1 id="hero-title" class="font-display tracking-tight text-brand-900 leading-[1.2] text-5xl sm:text-6xl md:text-7xl lg:text-8xl">
              CHILLER PAROU?<br />
              <span class="text-brand-500">TEMOS A PEÇA</span><br />
              <span class="relative inline-block">
                À PRONTA ENTREGA.
                <svg class="absolute left-0 -bottom-2 w-full h-3" viewBox="0 0 300 12" preserveAspectRatio="none" aria-hidden="true">
                  <path d="M2 8 Q 75 0 150 6 T 298 4" stroke="#ff901c" stroke-width="5" fill="none" stroke-linecap="round" />
                </svg>
              </span>
            </h1>

            <p class="mt-8 text-lg md:text-xl text-brand-900/80 font-sans max-w-xl leading-relaxed">
              +30 mil peças para chillers em estoque: <strong class="text-brand-900">compressores, gás refrigerante, placas eletrônicas, óleos lubrificantes, sensores, válvulas de expansão, tubos de cobre, filtros, motores, hélices e turbinas</strong>. <strong class="text-brand-900">Cotação pelo WhatsApp.</strong>
            </p>

            <!-- CTAs duplos -->
            <div class="mt-10 flex flex-col sm:flex-row items-stretch sm:items-center gap-4">
              <button
                type="button"
                class="cta cta--primary modal-trigger group relative inline-flex items-center justify-center gap-3 bg-brand-accent text-white font-sans font-extrabold text-lg md:text-xl py-5 px-8 md:px-10 rounded-full shadow-[0_8px_0_0_#c46400] hover:shadow-[0_3px_0_0_#c46400] hover:translate-y-[5px] transition-all"
                data-open-whatsapp-modal
                data-gtm-event="cta_click"
                data-gtm-location="hero_primary"
                data-gtm-label="pedir_cotacao_whatsapp"
                data-gtm-category="whatsapp"
              >
                <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6" aria-hidden="true">
                  <path d="M17.6 6.3A7.8 7.8 0 0 0 12 4a7.9 7.9 0 0 0-6.8 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.8 1h0a7.9 7.9 0 0 0 5.6-13.6zM12 19.4a6.5 6.5 0 0 1-3.3-.9l-.2-.1-2.5.6.7-2.4-.2-.3a6.6 6.6 0 1 1 12.2-3.5 6.6 6.6 0 0 1-6.7 6.6zm3.7-4.9c-.2-.1-1.2-.6-1.4-.7s-.3-.1-.5.1-.5.7-.6.8-.2.2-.4.1a5.4 5.4 0 0 1-2.6-2.3c-.2-.3.2-.3.5-1s.2-.3.1-.5-.5-1.2-.7-1.6-.3-.4-.4-.4h-.4a.8.8 0 0 0-.5.2 2.3 2.3 0 0 0-.7 1.7 4 4 0 0 0 .8 2.1 9 9 0 0 0 3.4 3c.5.2.9.3 1.2.4a2.8 2.8 0 0 0 1.3.1 2.1 2.1 0 0 0 1.4-1 1.7 1.7 0 0 0 .1-1c0-.1-.2-.2-.4-.3z" />
                </svg>
                PEDIR COTAÇÃO NO WHATSAPP
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5 group-hover:translate-x-1 transition-transform" aria-hidden="true">
                  <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </button>
              <a
                href="#categorias"
                class="inline-flex items-center justify-center gap-2 bg-white border-2 border-brand-900 text-brand-900 font-sans font-bold text-base md:text-lg py-[18px] px-8 rounded-full hover:bg-brand-900 hover:text-white transition-colors"
                data-gtm-event="nav_click"
                data-gtm-location="hero_secondary"
                data-gtm-label="ver_categorias"
                data-gtm-category="navegacao"
              >
                Ver categorias
              </a>
            </div>

            <!-- Microcopy -->
            <p class="mt-5 text-sm text-brand-900/60 font-sans flex items-center gap-2">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="w-4 h-4 text-brand-accent" aria-hidden="true">
                <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              Sem burocracia · Sem cadastro · Atendimento imediato
            </p>
          </div>

          <!-- Coluna visual: selo + card de stats -->
          <div class="lg:col-span-5 relative min-h-[380px] lg:min-h-[520px]">

            <!-- Card stats -->
            <div class="absolute bottom-0 left-0 right-0 lg:right-12 bg-brand-900 text-white rounded-3xl p-6 md:p-8 shadow-2xl">
              <div class="text-xs font-sans font-bold uppercase tracking-[0.2em] text-brand-accent mb-4">Comprovado na prática</div>
              <div class="grid grid-cols-2 gap-4">
                {site.estatisticas.map((e) => (
                  <div>
                    <div class="font-display text-4xl md:text-5xl leading-none text-white">{e.numero}</div>
                    <div class="mt-2 font-sans text-xs md:text-sm text-white/70 uppercase tracking-wider">{e.rotulo}</div>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============================================================
         FAIXA BENEFÍCIOS
         ============================================================ -->
    <section class="bg-brand-light py-8" aria-label="Benefícios">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          {[
            { label: 'Pronta entrega', sub: 'Despacho em até 24h' },
            { label: 'Atendimento técnico', sub: 'Equipe especialista em Refrigeração' },
          ].map((item) => (
            <div class="flex items-center gap-4 bg-white rounded-2xl p-5 shadow-sm">
              <div class="flex-shrink-0 w-11 h-11 rounded-full bg-brand-accent grid place-items-center" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3.5" class="w-6 h-6">
                  <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
              </div>
              <div>
                <div class="font-display text-xl text-brand-900 tracking-wide uppercase leading-none">{item.label}</div>
                <div class="font-sans text-sm text-brand-900/60 mt-1">{item.sub}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============================================================
         CATEGORIAS
         ============================================================ -->
    <section id="categorias" class="bg-white py-16 md:py-24" aria-labelledby="categorias-title">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6 mb-10">
          <div>
            <div class="font-sans text-sm uppercase tracking-[0.25em] text-brand-500 font-bold mb-3">
              O que temos em estoque
            </div>
            <h2 id="categorias-title" class="font-display text-4xl md:text-6xl text-brand-900 leading-[1.2] tracking-tight">
              ESCOLHA SUA CATEGORIA.<br />
              <span class="text-brand-500">PEÇA NO WHATSAPP.</span>
            </h2>
          </div>
          <button
            type="button"
            class="modal-trigger self-start md:self-auto inline-flex items-center gap-2 font-sans font-bold text-brand-accent hover:text-brand-900 transition-colors bg-transparent border-0 cursor-pointer p-0"
            data-open-whatsapp-modal
            data-gtm-event="cta_click"
            data-gtm-location="categorias_header"
            data-gtm-label="nao_achou"
            data-gtm-category="whatsapp"
          >
            Não achou? Pergunte no WhatsApp
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-5 h-5" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </button>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
          {categorias.map((cat, idx) => {
            const badge = categoryBadges[cat.id] ?? 'PRONTA ENTREGA';
            return (
              <article class={`category-card ${cat.data.destaque ? 'category-card--featured' : ''} group relative rounded-2xl overflow-hidden border-2 border-brand-light bg-white transition-all duration-200 hover:-translate-y-1 hover:border-brand-accent hover:shadow-[8px_8px_0_0_rgba(255,144,28,0.18)] focus-within:border-brand-accent focus-within:shadow-[8px_8px_0_0_rgba(255,144,28,0.18)]`}>
                {cat.data.imagem && (
                  <div class="aspect-[16/10] w-full overflow-hidden bg-brand-light">
                    <picture>
                      <source srcset={cat.data.imagem.replace(/\.jpg$/, '.webp')} type="image/webp" />
                      <img
                        src={cat.data.imagem}
                        alt={`${cat.data.nome} para chillers e refrigeração industrial`}
                        width="1000"
                        height="625"
                        loading="lazy"
                        decoding="async"
                        class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-500"
                      />
                    </picture>
                  </div>
                )}
                <div class="p-6 md:p-7 relative">
                  {badge && (
                    <span class="absolute -top-3 left-5 bg-brand-accent text-white font-display text-xs tracking-wider px-3 py-1.5 rounded-full shadow-md">
                      ★ {badge}
                    </span>
                  )}
                  <div class="flex items-baseline gap-3 mb-3">
                    <span class="font-display text-6xl md:text-7xl leading-none text-brand-accent/90 group-hover:text-brand-accent transition-colors" aria-hidden="true">
                      0{idx + 1}
                    </span>
                    <span class="font-sans text-[10px] uppercase tracking-[0.25em] text-brand-900/40 font-bold" aria-hidden="true">
                      Categoria
                    </span>
                  </div>
                  <h3 class="font-display text-2xl md:text-3xl text-brand-900 uppercase tracking-wide leading-tight mb-2">{cat.data.nome}</h3>
                  <p class="font-sans text-sm text-brand-900/70 mb-5 leading-relaxed">{cat.data.descricao}</p>
                  <button
                    type="button"
                    class={`modal-trigger inline-flex items-center gap-2 font-sans font-bold text-sm ${cat.data.destaque ? 'text-brand-accent' : 'text-brand-500'} hover:gap-3 transition-all bg-transparent border-0 cursor-pointer p-0`}
                    data-open-whatsapp-modal
                    data-gtm-event="cta_click"
                    data-gtm-location={`categoria_card_${cat.id}`}
                    data-gtm-label={`cotar_${cat.id}`}
                    data-gtm-category="whatsapp"
                  >
                    Cotar agora
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" class="w-4 h-4" aria-hidden="true">
                      <path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </button>
                </div>
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <!-- ============================================================
         FAIXA MARCAS — marquee auto-scroll
         ============================================================ -->
    <section id="marcas" class="bg-brand-500 py-12 md:py-16 overflow-hidden" aria-labelledby="marcas-title">
      <h2 id="marcas-title" class="sr-only">Trabalhamos com as melhores marcas do mercado de refrigeração</h2>
      <div class="marquee-wrapper" aria-hidden="true">
        <div class="marquee-track items-center">
          {Array.from({ length: 8 }).map(() => (
            <span class="font-display text-2xl md:text-4xl lg:text-5xl text-white uppercase tracking-wide leading-[1.3] whitespace-nowrap inline-flex items-center gap-7 md:gap-10 px-5 md:px-8">
              Trabalhamos com as melhores marcas do mercado de refrigeração
              <span class="text-brand-accent text-3xl md:text-5xl">★</span>
            </span>
          ))}
        </div>
      </div>
      <!-- Lista textual acessível com as marcas reais que a empresa atende -->
      <ul class="sr-only">
        {marcas.map((m) => <li>{m.data.nome}</li>)}
      </ul>
    </section>

    <!-- ============================================================
         PROVA SOCIAL — números gigantes + CTA imenso
         ============================================================ -->
    <section class="bg-white py-20 md:py-28 relative overflow-hidden" aria-labelledby="prova-social-title">
      <div class="absolute inset-0 pointer-events-none opacity-[0.04]" aria-hidden="true">
        <div class="font-display text-[20rem] leading-none text-brand-500 whitespace-nowrap -rotate-6 -mt-10">
          ORIGINAL · ORIGINAL
        </div>
      </div>
      <div class="relative max-w-7xl mx-auto px-4 md:px-8">
        <div class="text-center mb-14">
          <div class="font-sans text-sm uppercase tracking-[0.25em] text-brand-500 font-bold mb-4">
            Números que falam por si
          </div>
          <h2 id="prova-social-title" class="font-display text-5xl md:text-7xl text-brand-900 leading-[1.2] tracking-tight">
            MAIS DE <span class="text-brand-accent">5 ANOS</span><br />
            MANTENDO CHILLERS LIGADOS.
          </h2>
        </div>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-10 mb-16">
          {site.estatisticas.map((e) => (
            <div class="text-center">
              <div class="font-display text-6xl md:text-8xl text-brand-500 leading-none">{e.numero}</div>
              <div class="mt-3 font-sans text-xs md:text-sm uppercase tracking-wider text-brand-900/70 font-bold">{e.rotulo}</div>
            </div>
          ))}
        </div>

        <!-- CTA imenso central -->
        <div class="relative max-w-3xl mx-auto">
          <!-- Seta decorativa: só aparece em lg+ onde há espaço livre à esquerda -->
          <svg viewBox="0 0 120 80" class="hidden lg:block absolute -left-36 xl:-left-44 top-1/2 -translate-y-1/2 w-28 xl:w-32 text-brand-accent rotate-12 pointer-events-none" aria-hidden="true">
            <path d="M5 40 Q 40 10 95 40" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round" />
            <path d="M85 28 L 100 40 L 85 52" stroke="currentColor" stroke-width="4" fill="none" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
          <button
            type="button"
            class="cta cta--primary modal-trigger group flex flex-col w-full bg-brand-accent text-white rounded-3xl p-6 sm:p-8 md:p-10 text-center shadow-[0_12px_0_0_#c46400] hover:shadow-[0_4px_0_0_#c46400] hover:translate-y-2 transition-all border-0"
            data-open-whatsapp-modal
            data-gtm-event="cta_click"
            data-gtm-location="cta_central"
            data-gtm-label="falar_com_especialista"
            data-gtm-category="whatsapp"
          >
            <div class="font-sans text-[10px] sm:text-xs md:text-sm uppercase tracking-[0.25em] text-white/80 mb-3">
              1 clique = 1 cotação
            </div>
            <div class="font-sans font-black uppercase text-2xl sm:text-3xl md:text-4xl lg:text-5xl leading-[1.2] tracking-tight">
              Falar com especialista agora
            </div>
          </button>
        </div>
      </div>
    </section>

    <!-- ============================================================
         DEPOIMENTOS
         ============================================================ -->
    <section id="depoimentos" class="bg-brand-light py-16 md:py-24" aria-labelledby="depoimentos-title">
      <div class="max-w-7xl mx-auto px-4 md:px-8">
        <div class="mb-12 text-center">
          <div class="font-sans text-sm uppercase tracking-[0.25em] text-brand-500 font-bold mb-3">
            Clientes reais · Resultados reais
          </div>
          <h2 id="depoimentos-title" class="font-display text-4xl md:text-6xl text-brand-900 leading-[1.2] tracking-tight mb-6">
            +17 MIL EMPRESAS <span class="text-brand-accent">CONFIAM</span><br /> NA CHILLER PEÇAS
          </h2>
          <!-- Selo Google: prova social verificável (clicável → abre Google Reviews) -->
          {site.googleReviewsUrl ? (
            <a
              href={site.googleReviewsUrl}
              target="_blank"
              rel="noopener noreferrer"
