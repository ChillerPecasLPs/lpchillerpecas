---
/**
 * Modal de captura de WhatsApp + envio ao webhook Hablla.
 *
 * Comportamento:
 *   - Qualquer elemento com [data-open-whatsapp-modal] dispara o modal
 *   - Lê data-gtm-location do trigger para carimbar o evento
 *   - Valida telefone BR (10-11 dígitos), aplica máscara
 *   - POST JSON ao webhook com payload completo (utm, click_ids, attribution, session)
 *   - Em sucesso: abre wa.me em nova aba com telefone pré-preenchido
 *   - Em erro: mostra mensagem e permite retry
 *   - Dispara eventos dataLayer em cada passo
 */
interface Props {
  waNumber: string;          // "5511940518767"
  webhookUrl: string;        // URL Hablla
  waMessage?: string;        // mensagem pré-preenchida no wa.me (sem o telefone)
}
const {
  waNumber,
  webhookUrl,
  waMessage = 'Olá! Acabei de enviar meu contato pelo site e gostaria de uma cotação.',
} = Astro.props;
---

<dialog
  id="whatsapp-modal"
  class="whatsapp-modal"
  aria-labelledby="wa-modal-title"
  aria-describedby="wa-modal-desc"
>
  <form class="whatsapp-modal__form" id="whatsapp-form" novalidate>
    <!-- Honeypot anti-bot: campo escondido. Bots tendem a preencher TODOS os inputs;
         humanos não veem este campo. Se vier preenchido → descartamos silenciosamente. -->
    <div aria-hidden="true" style="position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;">
      <label for="wa-website">Não preencha este campo:</label>
      <input
        id="wa-website"
        type="text"
        name="website"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    <button
      type="button"
      class="whatsapp-modal__close"
      aria-label="Fechar"
      data-close-modal
    >×</button>

    <div class="whatsapp-modal__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="currentColor" class="w-8 h-8">
        <path d="M17.6 6.3A7.8 7.8 0 0 0 12 4a7.9 7.9 0 0 0-6.8 11.9L4 20l4.2-1.1a7.9 7.9 0 0 0 3.8 1h0a7.9 7.9 0 0 0 5.6-13.6zM12 19.4a6.5 6.5 0 0 1-3.3-.9l-.2-.1-2.5.6.7-2.4-.2-.3a6.6 6.6 0 1 1 12.2-3.5 6.6 6.6 0 0 1-6.7 6.6zm3.7-4.9c-.2-.1-1.2-.6-1.4-.7s-.3-.1-.5.1-.5.7-.6.8-.2.2-.4.1a5.4 5.4 0 0 1-2.6-2.3c-.2-.3.2-.3.5-1s.2-.3.1-.5-.5-1.2-.7-1.6-.3-.4-.4-.4h-.4a.8.8 0 0 0-.5.2 2.3 2.3 0 0 0-.7 1.7 4 4 0 0 0 .8 2.1 9 9 0 0 0 3.4 3c.5.2.9.3 1.2.4a2.8 2.8 0 0 0 1.3.1 2.1 2.1 0 0 0 1.4-1 1.7 1.7 0 0 0 .1-1c0-.1-.2-.2-.4-.3z"/>
      </svg>
    </div>

    <h2 id="wa-modal-title">Receba sua cotação em minutos</h2>
    <p id="wa-modal-desc">
      Informe seu WhatsApp que retornamos com o orçamento personalizado.
    </p>

    <label for="wa-phone">Seu WhatsApp</label>
    <input
      id="wa-phone"
      name="phone"
      type="tel"
      inputmode="numeric"
      autocomplete="tel"
      placeholder="(11) 9XXXX-XXXX"
      required
      minlength="14"
      maxlength="15"
      aria-invalid="false"
      aria-describedby="wa-phone-error"
    />
    <span id="wa-phone-error" class="whatsapp-modal__error" role="alert"></span>

    <button
      type="submit"
      class="cta cta--primary whatsapp-modal__submit"
      id="wa-submit"
      data-gtm-event="cta_click"
      data-gtm-location="modal"
      data-gtm-label="solicitar_orcamento"
      data-gtm-category="form"
    >
      <span class="whatsapp-modal__submit-label">Solicitar orçamento</span>
      <span class="whatsapp-modal__submit-spinner" aria-hidden="true"></span>
    </button>

    <p class="whatsapp-modal__disclaimer">
      Ao enviar, você autoriza a Chiller Peças (CNPJ 35.028.609/0001-53) a entrar em
      contato via WhatsApp/telefone para atender sua cotação, conforme nossa
      <a href="/privacidade" target="_blank" rel="noopener">Política de Privacidade</a>.
      Não realizamos vendas online — propostas comerciais são enviadas após contato humano.
    </p>

    <div class="whatsapp-modal__status" role="status" aria-live="polite"></div>
  </form>
</dialog>

<script
  is:inline
  define:vars={{ waNumber, webhookUrl, waMessage }}
>
  (function () {
    const modal = document.getElementById('whatsapp-modal');
    const form = document.getElementById('whatsapp-form');
    const input = document.getElementById('wa-phone');
    const submit = document.getElementById('wa-submit');
    const errorEl = document.getElementById('wa-phone-error');
    const statusEl = modal?.querySelector('.whatsapp-modal__status');
    if (!modal || !form || !input || !submit) return;

    let lastTriggerLocation = 'unknown';
    let attemptCount = 0;

    // ---------- dataLayer helpers (inline p/ nao depender de bundle) -----------
    function track(name, params = {}) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: name,
        timestamp: new Date().toISOString(),
        page_path: location.pathname,
        page_location: location.href,
        ...params,
      });
    }

    // ---------- attribution ----------
    const UTM_KEYS = ['utm_source','utm_medium','utm_campaign','utm_term','utm_content','utm_id'];
    const CLICK_KEYS = ['gclid','gbraid','wbraid','fbclid','msclkid','ttclid'];

    function getAttribution() {
      const url = new URL(location.href);
      let first = null, last = null;
      try { first = JSON.parse(localStorage.getItem('cp_first_touch') || 'null'); } catch {}
      try { last  = JSON.parse(localStorage.getItem('cp_last_touch')  || 'null'); } catch {}

      const utm = {};
      const click_ids = {};
      for (const k of UTM_KEYS)   utm[k]       = url.searchParams.get(k) || (last && last[k]) || '';
      for (const k of CLICK_KEYS) click_ids[k] = url.searchParams.get(k) || (last && last[k]) || '';

      return {
        utm, click_ids,
        attribution: { first_touch: first, last_touch: last },
        source_url: url.href,
        page_path: url.pathname,
        referrer: document.referrer || '',
        user_agent: navigator.userAgent,
        viewport: { w: innerWidth, h: innerHeight },
        session_id: sessionStorage.getItem('cp_session') || '',
      };
    }

    // ---------- masking / validation (BR rigorosa, espelha src/lib/phone-validator.ts) ----------
    const VALID_DDDS = new Set([
      11,12,13,14,15,16,17,18,19,
      21,22,24,27,28,
      31,32,33,34,35,37,38,
      41,42,43,44,45,46,47,48,49,51,53,54,55,
      61,62,63,64,65,66,67,68,69,
      71,73,74,75,77,79,
      81,82,83,84,85,86,87,88,89,
      91,92,93,94,95,96,97,98,99,
    ]);

    const VALIDATION_MESSAGES = {
      tamanho: 'Informe DDD + número (10 ou 11 dígitos).',
      repetido: 'Esse número não parece válido. Verifique e tente novamente.',
      ddd_invalido: 'Esse DDD não existe. Confira o código de área.',
      formato_celular: 'Celular com 11 dígitos deve começar com 9 após o DDD.',
    };

    function applyMask(v) {
      const digits = v.replace(/\D/g, '').slice(0, 11);
      if (digits.length === 0) return '';
      if (digits.length < 3)  return `(${digits}`;
      if (digits.length < 8)  return `(${digits.slice(0,2)}) ${digits.slice(2)}`;
      if (digits.length < 11) return `(${digits.slice(0,2)}) ${digits.slice(2,6)}-${digits.slice(6)}`;
      return `(${digits.slice(0,2)}) ${digits.slice(2,7)}-${digits.slice(7)}`;
    }

    function validatePhone(masked) {
      const digits = (masked || '').replace(/\D/g, '');
      if (digits.length < 10 || digits.length > 11) return { ok: false, reason: 'tamanho' };
      if (/^(\d)\1+$/.test(digits)) return { ok: false, reason: 'repetido' };
      const ddd = parseInt(digits.slice(0, 2), 10);
      if (!VALID_DDDS.has(ddd)) return { ok: false, reason: 'ddd_invalido' };
      if (digits.length === 11 && digits[2] !== '9') return { ok: false, reason: 'formato_celular' };
      return { ok: true };
    }

    function digitsOnly(masked) {
      return masked.replace(/\D/g, '');
    }

    function maskForTracking(digits) {
      if (digits.length < 6) return '***';
      return `+55${digits.slice(0,2)}****${digits.slice(-4)}`;
    }

    // ---------- Lead queue (fila offline em localStorage) ----------
    const QUEUE_KEY = 'cp_pending_leads';
    const MAX_AGE_MS = 24 * 3600 * 1000;
    const MAX_QUEUE_ATTEMPTS = 5;

    function queueRead() {
      try { const raw = localStorage.getItem(QUEUE_KEY); return raw ? JSON.parse(raw) || [] : []; }
      catch { return []; }
    }
    function queueWrite(items) {
      try { localStorage.setItem(QUEUE_KEY, JSON.stringify(items)); } catch {}
    }
    function enqueueLead(payload) {
      const q = queueRead();
      q.push({ payload, ts: Date.now(), attempts: 0 });
      queueWrite(q);
    }
    async function flushQueue() {
      const q = queueRead();
      if (q.length === 0) return { sent: 0, failed: 0, expired: 0 };
      const cutoff = Date.now() - MAX_AGE_MS;
      let sent = 0, failed = 0, expired = 0;
      const remaining = [];
      for (const item of q) {
        if (item.ts < cutoff || item.attempts >= MAX_QUEUE_ATTEMPTS) { expired++; continue; }
        try {
          const ctrl = new AbortController();
          const t = setTimeout(() => ctrl.abort(), 8000);
          const r = await fetch(webhookUrl, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ ...item.payload, retry_from_queue: true, retry_attempt: item.attempts + 1 }),
            signal: ctrl.signal,
            keepalive: true,
          });
          clearTimeout(t);
          if (r.ok) { sent++; } else { remaining.push({ ...item, attempts: item.attempts + 1 }); failed++; }
        } catch { remaining.push({ ...item, attempts: item.attempts + 1 }); failed++; }
      }
      queueWrite(remaining);
      return { sent, failed, expired };
    }

    // ---------- POST com retry exponencial + AbortController ----------
    async function postWithRetry(url, payload, maxAttempts) {
      maxAttempts = maxAttempts || 3;
      let lastErr;
      for (let attempt = 1; attempt <= maxAttempts; attempt++) {
        const ctrl = new AbortController();
        const timer = setTimeout(() => ctrl.abort(), 8000);
        try {
          const r = await fetch(url, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
            mode: 'cors',
            keepalive: true,
            signal: ctrl.signal,
          });
          clearTimeout(timer);
          if (!r.ok) throw new Error('http_' + r.status);
          if (attempt > 1) {
            track('lp_form_submit_retry_success', { attempt });
          }
          return r;
        } catch (err) {
          clearTimeout(timer);
          lastErr = err;
          if (attempt >= maxAttempts) break;
          const delay = 800 * Math.pow(3, attempt - 1); // 800ms → 2400ms
          track('lp_form_submit_retry', {
            attempt,
            error_code: String((err && err.message) || 'unknown'),
          });
          await new Promise((res) => setTimeout(res, delay));
        }
      }
      throw lastErr || new Error('unknown');
    }

    // ---------- open / close ----------
    function openModal(trigger) {
      lastTriggerLocation = (trigger && trigger.getAttribute('data-gtm-location')) || 'unknown';
      attemptCount = 0;
      clearStatus();
      errorEl.textContent = '';
      input.setAttribute('aria-invalid', 'false');
      try { modal.showModal(); } catch { modal.setAttribute('open', ''); }
      setTimeout(() => input.focus(), 50);
      track('lp_modal_open', { trigger_location: lastTriggerLocation });
    }

    function closeModal(method) {
      try { modal.close(); } catch { modal.removeAttribute('open'); }
      track('lp_modal_close', { method, trigger_location: lastTriggerLocation });
    }

    function setStatus(message, kind) {
      if (!statusEl) return;
      statusEl.textContent = message;
      statusEl.dataset.kind = kind || '';
    }

    function clearStatus() {
      if (!statusEl) return;
      statusEl.textContent = '';
      delete statusEl.dataset.kind;
    }

    function setLoading(on) {
      submit.classList.toggle('is-loading', !!on);
      submit.disabled = !!on;
    }

    // ---------- bind triggers ----------
    document.querySelectorAll('[data-open-whatsapp-modal]').forEach((el) => {
      el.addEventListener('click', (ev) => {
        ev.preventDefault();
        openModal(el);
      });
    });

    // Close by backdrop click (clicar fora do form)
    modal.addEventListener('click', (ev) => {
      if (ev.target === modal) closeModal('backdrop');
    });

    // Close button
    modal.querySelectorAll('[data-close-modal]').forEach((el) => {
      el.addEventListener('click', () => closeModal('button'));
    });

    // ESC handled by native <dialog> — capture it for tracking
    modal.addEventListener('cancel', () => {
      // deixa o comportamento default (fechar), só trackeia
      setTimeout(() => track('lp_modal_close', { method: 'esc', trigger_location: lastTriggerLocation }), 0);
    });

    // ---------- input mask ----------
    input.addEventListener('input', () => {
      const masked = applyMask(input.value);
      input.value = masked;
      if (errorEl.textContent) errorEl.textContent = '';
      input.setAttribute('aria-invalid', 'false');
    });

    // ---------- submit (idempotente, com retry + fila offline + fallback hard wa.me) ----------
    const honeypot = document.getElementById('wa-website');

    form.addEventListener('submit', async (ev) => {
      ev.preventDefault();

      // GUARD #1 — Idempotência: bloquear double-click ANTES de qualquer await
      if (submit.disabled) return;
      submit.disabled = true;

      // GUARD #2 — Honeypot: bot caiu na armadilha → descarta silenciosamente
      if (honeypot && honeypot.value) {
        track('lp_form_validation_fail', {
          reason: 'honeypot',
          trigger_location: lastTriggerLocation,
        });
        // Pretende ter funcionado pro bot não suspeitar; não envia nada
        submit.disabled = false;
        return;
      }

      const masked = input.value.trim();
      const validation = validatePhone(masked);

      track('lp_form_submit_attempt', {
        phone_valid: validation.ok,
        trigger_location: lastTriggerLocation,
      });

      if (!validation.ok) {
        const msg = VALIDATION_MESSAGES[validation.reason] || 'WhatsApp inválido.';
        errorEl.textContent = msg;
        input.setAttribute('aria-invalid', 'true');
        input.focus();
        track('lp_form_validation_fail', {
          reason: validation.reason,
          trigger_location: lastTriggerLocation,
        });
        submit.disabled = false;
        return;
      }

      const digits = digitsOnly(masked);
      const phoneE164 = '+55' + digits;
      const masked_log = maskForTracking(digits);
      attemptCount += 1;

      const attribution = getAttribution();
      const payload = {
        phone: phoneE164,
        phone_local: masked,
        source: 'landing-page',
        cta_location: lastTriggerLocation,
        ...attribution,
        timestamp: new Date().toISOString(),
      };

      setLoading(true);
      setStatus('Enviando…', 'loading');

      // Build URL do wa.me — vai ser usado mesmo em erro como fallback hard
      const text = encodeURIComponent(waMessage + ' Meu WhatsApp é ' + masked + '.');
      const waUrl = `https://wa.me/${waNumber}?text=${text}`;

      let webhookOk = false;
      try {
        await postWithRetry(webhookUrl, payload, 3);
        webhookOk = true;

        track('lp_form_submit_success', {
          phone_masked: masked_log,
          trigger_location: lastTriggerLocation,
          attribution_utm_source: attribution.utm.utm_source,
          attribution_utm_campaign: attribution.utm.utm_campaign,
          attribution_gclid: attribution.click_ids.gclid,
          attribution_session_id: attribution.session_id,
        });

        setStatus('Recebemos! Abrindo WhatsApp…', 'success');
      } catch (err) {
        // Webhook falhou após N tentativas → enfileira pro retry futuro
        const errorCode = String((err && err.message) || 'unknown');
        try { enqueueLead(payload); } catch {}
        track('lp_form_submit_queued', {
          error_code: errorCode,
          attempt: attemptCount,
          trigger_location: lastTriggerLocation,
        });
        setStatus('Tudo certo! Te levando ao WhatsApp…', 'success');
      } finally {
        setLoading(false);
      }

      // FALLBACK HARD — abre wa.me mesmo se webhook caiu 100%.
      // Lead nunca é perdido: se webhook morreu, o user ainda tem o canal direto.
      setTimeout(() => {
        window.open(waUrl, '_blank', 'noopener');
        track('lp_whatsapp_redirect', {
          trigger_location: lastTriggerLocation,
          webhook_ok: webhookOk,
        });
        closeModal('submit_success');
      }, 450);
    });

    // ---------- flush da fila offline ao voltar online (ou ao carregar a página) ----------
    async function tryFlush() {
      try {
        const r = await flushQueue();
        if (r.sent > 0 || r.expired > 0) {
          track('lp_lead_queue_flushed', r);
        }
      } catch {}
    }
    if (typeof navigator !== 'undefined' && navigator.onLine) {
      // Tenta esvaziar fila pendente já no boot
      setTimeout(tryFlush, 1500);
    }
    window.addEventListener('online', tryFlush);
  })();
</script>
